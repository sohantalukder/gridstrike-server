NODE_ENV="prod"
PORT=3000

SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key"
SUPABASE_SECRET_KEY="sb_secret_your_key"
SUPABASE_JWKS_URL="https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json"

DATABASE_URL="postgresql://postgres:<POSTGRES_PASSWORD>@db.your-project-ref.supabase.co:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:<POSTGRES_PASSWORD>@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET="replace-with-secure-access-secret"
JWT_REFRESH_SECRET="replace-with-secure-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
