{
  "name": "gridstrike-server",
  "version": "0.1.0",
  "private": true,
  "description": "GridStrike backend API",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "db:check": "npm run prisma:generate && node scripts/db-check.js",
    "lint": "eslint 'src/**/*.ts' --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:migrate:status": "npx prisma migrate status",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:migrate:reset": "npx prisma migrate reset --force",
    "env:check": "node scripts/env-audit.js",
    "db:reach": "node scripts/db-reachability.js",
    "db:migrate:local": "npm run prisma:generate && npm run prisma:migrate",
    "db:migrate:prod": "npm run prisma:generate && npm run prisma:migrate:deploy",
    "scenarios:build": "node scripts/scenario-packs.js",
    "scenarios:publish": "node scripts/scenario-packs.js --upload"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.17.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "fflate": "^0.8.3",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@nestjs/cli": "^10.4.3",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.8",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^5.17.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "wrangler": "^4.113.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "watchman": false
  }
}
